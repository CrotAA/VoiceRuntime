# App server
HOST=0.0.0.0
PORT=3010

# Default LLM runtime
VOICERUNTIME_BASE_URL=http://127.0.0.1:8080/v1
VOICERUNTIME_MODEL=Qwen/Qwen3.5-9B
VOICERUNTIME_SYSTEM_PROMPT=You are a concise, capable assistant running in VoiceRuntime.
VOICERUNTIME_MAX_TOKENS=4096

# ASR gateway / FunASR
VOICERUNTIME_ASR_AUTOSTART=true
VOICERUNTIME_ASR_PYTHON=python3
VOICERUNTIME_ASR_HOST=127.0.0.1
VOICERUNTIME_ASR_PORT=10096
# VOICERUNTIME_ASR_URL=ws://127.0.0.1:10096
FUNASR_MODEL=paraformer-zh-streaming
FUNASR_CHUNK_SIZE=0,8,4
FUNASR_SAMPLE_RATE=16000
FUNASR_ENCODER_LOOK_BACK=4
FUNASR_DECODER_LOOK_BACK=1

# TTS gateway / MeloTTS
VOICERUNTIME_TTS_AUTOSTART=true
VOICERUNTIME_TTS_HOST=127.0.0.1
VOICERUNTIME_TTS_PORT=10097
# VOICERUNTIME_TTS_URL=http://127.0.0.1:10097
VOICERUNTIME_TTS_PYTHON=/path/to/python
VOICERUNTIME_TTS_TIMEOUT_MS=120000

MELOTTS_REPO=/path/to/MeloTTS
MELOTTS_LANGUAGE=ZH
MELOTTS_SPEAKER=ZH
# For NVIDIA GPU set cuda, otherwise keep cpu.
MELOTTS_DEVICE=cpu
MELOTTS_SPEED=1.0
MELOTTS_MAX_CHARS=1200
MELOTTS_WARMUP=true

# Wake word
OPENWAKEWORD_MODEL=hey_jarvis
OPENWAKEWORD_MODEL_PATH=
OPENWAKEWORD_THRESHOLD=0.5
OPENWAKEWORD_PATIENCE=1
OPENWAKEWORD_VAD_THRESHOLD=0
OPENWAKEWORD_ENABLE_SPEEX=false

# Legacy LORARUNTIME_* variables are still accepted for backward compatibility.
